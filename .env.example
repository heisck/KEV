# ─────────────────────────────────────────────────────────────
# KEV — MASTER environment reference (placeholders only — NEVER commit real values)
# Copy the relevant block into each service's own .env:
#   frontend/.env   backend/.env   ml/.env
# In CI/prod these come from GitHub Actions secrets / EAS secrets / host env.
# ─────────────────────────────────────────────────────────────

# ===== Frontend (Expo) — only EXPO_PUBLIC_* are bundled into the app =====
EXPO_PUBLIC_API_URL=http://localhost:8080
EXPO_PUBLIC_ENV=development
EXPO_PUBLIC_SENTRY_DSN=your-frontend-sentry-dsn-here
# Google OAuth client IDs (from Google Cloud Console → Credentials)
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your-web-client-id-here.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=your-ios-client-id-here.apps.googleusercontent.com
# Used only by EAS / Sentry CLI at build time (NOT bundled):
SENTRY_AUTH_TOKEN=your-sentry-auth-token-here
SENTRY_ORG=your-sentry-org-here
SENTRY_PROJECT_FRONTEND=kev-frontend

# ===== Backend (Spring Boot) =====
# Neon serverless Postgres — use the POOLED connection string, sslmode=require
SPRING_DATASOURCE_URL=jdbc:postgresql://your-neon-pooled-host.neon.tech/kev?sslmode=require
SPRING_DATASOURCE_USERNAME=your-neon-user-here
SPRING_DATASOURCE_PASSWORD=your-neon-password-here
# Upstash Redis (TLS) — host/port/password from the Upstash console
UPSTASH_REDIS_HOST=your-upstash-host-here.upstash.io
UPSTASH_REDIS_PORT=6379
UPSTASH_REDIS_PASSWORD=your-upstash-password-here
# Auth — JWT signing secret (>= 32 bytes) and accepted Google client IDs (comma-separated)
JWT_SECRET=changeme-generate-a-long-random-secret-min-32-bytes
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=30
GOOGLE_CLIENT_IDS=your-web-client-id-here.apps.googleusercontent.com,your-ios-client-id-here.apps.googleusercontent.com
# Observability
SENTRY_DSN_BACKEND=your-backend-sentry-dsn-here
# CORS — comma-separated allowed origins for the app/web
APP_CORS_ALLOWED_ORIGINS=http://localhost:8081,http://localhost:19006

# ===== ML service (FastAPI) =====
HF_TOKEN=your-hugging-face-token-here
HF_FACE_MODEL_ID=your-org/your-face-model-here
ML_SENTRY_DSN=your-ml-sentry-dsn-here
ML_PORT=8000
