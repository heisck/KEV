# ─────────────────────────────────────────────────────────────
# KEV — SINGLE root environment file (placeholders only — NEVER commit real values)
# Copy this to `.env` at the repo root; all three services read it directly:
#   frontend (app.config.ts) · backend (run-backend.mjs) · ml (run-ml.mjs)
# All standard SaaS names (DATABASE_URL, REDIS_URL, BACKEND_URL, etc.) are automatically
# recognized and mapped across all three services.
# ─────────────────────────────────────────────────────────────

# ===== Global & Service URLs =====
# Backend API URL (Automatically mapped to EXPO_PUBLIC_API_URL for Expo)
BACKEND_URL=http://localhost:8080

# ===== Database Connection (Local Docker or Neon) =====
# Default local dev (Docker Postgres brought up automatically by `npm run dev`):
DATABASE_URL=postgres://kev:kev@localhost:5432/kev
# Or paste your Neon serverless Postgres URL:
# DATABASE_URL=postgres://alex:your-password@ep-xxxx-pooler.region.aws.neon.tech/neondb?sslmode=require

# ===== Redis & Caching (Local Docker or Upstash) =====
# Default local dev (Docker Redis brought up automatically by `npm run dev`):
REDIS_URL=redis://localhost:6379
# Or paste your Upstash Redis URL:
# REDIS_URL=rediss://default:your-password@your-upstash-host.upstash.io:6379

# ===== Media Storage (Cloudinary) =====
# Paste the exact CLOUDINARY_URL copied from your Cloudinary dashboard:
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name

# ===== Authentication & OAuth =====
# Google OAuth Client IDs (from Google Cloud Console)
GOOGLE_WEB_CLIENT_ID=your-web-client-id-here.apps.googleusercontent.com
GOOGLE_IOS_CLIENT_ID=your-ios-client-id-here.apps.googleusercontent.com
# JWT signing secret (>= 32 bytes)
JWT_SECRET=changeme-generate-a-long-random-secret-min-32-bytes
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=30

# ===== ML Service (FastAPI) =====
HF_TOKEN=your-hugging-face-token-here
HF_FACE_MODEL_ID=your-org/your-face-model-here
ML_PORT=8000
FACE_MODEL_NAME=buffalo_sc
FACE_MATCH_THRESHOLD=0.35

# ===== Sentry Observability =====
FRONTEND_SENTRY_DSN=your-frontend-sentry-dsn-here
BACKEND_SENTRY_DSN=your-backend-sentry-dsn-here
ML_SENTRY_DSN=your-ml-sentry-dsn-here

# ===== Build & Deployment (EAS / Sentry CLI) =====
SENTRY_AUTH_TOKEN=your-sentry-auth-token-here
SENTRY_ORG=your-sentry-org-here
SENTRY_PROJECT_FRONTEND=kev-frontend
APP_CORS_ALLOWED_ORIGINS=http://localhost:8081,http://localhost:19006
KEV_DIRECTORY_PROVIDER=mock
ML_BASE_URL=http://localhost:8000

