# Frontend (Expo). Only EXPO_PUBLIC_* values are bundled into the app.
# Copy to frontend/.env and fill with real values (never commit .env).
EXPO_PUBLIC_API_URL=http://localhost:8080
EXPO_PUBLIC_ENV=development
EXPO_PUBLIC_SENTRY_DSN=your-frontend-sentry-dsn-here
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your-web-client-id-here.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=your-ios-client-id-here.apps.googleusercontent.com

# Build-time only (NOT bundled) — used by EAS builds / Sentry source-map upload:
SENTRY_AUTH_TOKEN=your-sentry-auth-token-here
SENTRY_ORG=your-sentry-org-here
SENTRY_PROJECT_FRONTEND=kev-frontend
EAS_PROJECT_ID=your-eas-project-id-here
