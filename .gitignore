# ─────────────────────────────────────────────────────────────
# KEV monorepo .gitignore  (frontend / backend / ml)
# Security rule: NEVER commit secrets. Only *.example env files are tracked.
# ─────────────────────────────────────────────────────────────

# ===== Secrets / env =====
.env
.env.*
!.env.example
!**/.env.example
*.local
secrets/
*.pem
*.key
*.p8
*.p12
*.keystore
*.jks
google-services.json
GoogleService-Info.plist
serviceAccount*.json

# ===== Node / JS =====
node_modules/
.npm/
.pnp.*
*.tsbuildinfo
.eslintcache
coverage/
*.lcov
.turbo/
dist/
build/
out/

# ===== Expo / React Native =====
.expo/
.expo-shared/
frontend/.expo/
web-build/
expo-env.d.ts
*.orig.*
# Native projects are generated by `expo prebuild` — keep them out of VCS by default
frontend/android/
frontend/ios/
# Metro
.metro-health-check*
# Reassure perf baselines (machine-specific)
.reassure/

# ===== Java / Maven (backend) =====
backend/target/
*.class
*.jar
!**/maven-wrapper.jar
*.war
*.ear
hs_err_pid*
replay_pid*
.mvn/timing.properties
.mvn/wrapper/maven-wrapper.jar
dependency-check-report.*

# ===== Python (ml) =====
ml/.venv/
.venv/
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.egg-info/
.python-version-local

# ===== Hugging Face / ML model caches =====
.cache/
ml/.hf-cache/
*.safetensors
*.bin
*.onnx
*.pt

# ===== Logs =====
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ===== IDE / Editor =====
.idea/
*.iml
.vscode/*
!.vscode/extensions.json
!.vscode/settings.shared.json
*.swp
*.swo

# ===== OS =====
.DS_Store
Thumbs.db
desktop.ini

# ===== Test / build artifacts =====
*.tgz
test-results/
playwright-report/
