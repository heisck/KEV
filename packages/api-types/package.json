{
  "name": "@kev/api-types",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "TypeScript types generated from the backend OpenAPI schema (source of truth for the API contract).",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "generate": "node ../../scripts/gen-api-types.mjs"
  },
  "devDependencies": {
    "typescript": "^6.0.3"
  }
}
