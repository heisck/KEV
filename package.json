{
  "name": "kev",
  "version": "0.0.0",
  "private": true,
  "description": "KEV — campus/exam app monorepo (Expo frontend + Spring Boot backend + Python ML service).",
  "license": "UNLICENSED",
  "workspaces": [
    "frontend",
    "packages/*"
  ],
  "engines": {
    "node": ">=22",
    "npm": ">=10"
  },
  "packageManager": "npm@10.9.2",
  "scripts": {
    "dev": "concurrently -k -n web,api,ml -c cyan,green,magenta \"npm:dev:frontend\" \"npm:dev:backend\" \"npm:dev:ml\"",
    "dev:frontend": "npm run start --workspace frontend",
    "dev:backend": "node scripts/run-backend.mjs spring-boot:run",
    "dev:ml": "node scripts/run-ml.mjs dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "knip": "knip",
    "gen:api-types": "node scripts/gen-api-types.mjs",
    "backend": "node scripts/run-backend.mjs",
    "backend:test": "node scripts/run-backend.mjs verify",
    "ml": "node scripts/run-ml.mjs",
    "ml:test": "node scripts/run-ml.mjs test",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,jsonc,md,mdx,yml,yaml,css}": [
      "prettier --write --ignore-unknown"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^19.6.1",
    "@commitlint/config-conventional": "^21.0.2",
    "concurrently": "^9.1.2",
    "eslint": "^9.39.4",
    "husky": "^9.1.7",
    "knip": "^5.43.0",
    "lint-staged": "^15.3.0",
    "openapi-typescript": "^7.5.0",
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.3"
  }
}
