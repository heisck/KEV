# React Native / Expo community libraries frequently publish lagging peer
# ranges during the RN 0.85 + React 19 transition. legacy-peer-deps lets the
# npm-workspaces install resolve like the Expo CLI does, instead of hard-failing
# on advisory peer mismatches. Real vulnerabilities are still caught by
# `npm audit` (run explicitly in CI), and Expo compatibility by `expo-doctor`.
legacy-peer-deps=true
fund=false
